# ============================================================
# Anchor Spoke Node — Environment Configuration
# ============================================================
# Provided by Anchor during enterprise onboarding.
# Keep this file SECRET — never commit to version control.
# ============================================================

# Your unique entity identifier (provided by Anchor)
ENTITY_ID=your_entity_id_here

# Your Machine Access Token (provided at registration)
MAT=0x_your_mat_token_here

# Anchor Hub WebSocket URL (do not change)
HUB_URL=wss://api.anchorgovernance.tech/ws/spoke

# Hub's public encryption key (provided by Anchor, 64 hex chars)
# The Spoke uses this to encrypt data before sending — only the Hub can decrypt.
HUB_PUBKEY=your_64_char_hub_pubkey_here

# Internal port (change only if 8001 is taken on your server)
SPOKE_PORT=8001

# Persistent data directory (mapped to Docker volume — do not change)
DATA_DIR=/data
